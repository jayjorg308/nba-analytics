# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Installed third-party agent skills (own upstream/license; managed by `skills`,
# not vendored here — committing would drift from upstream and fight updates)
.claude/skills/
/.agents/

# Python (ingestion layer)
__pycache__/
*.py[cod]
.venv/
venv/

# Data landing + derived layers (pulled/computed locally; not committed by default).
# Anchored to the repo root: public/data/ (the synced deployment payload) IS committed.
/data/

# Scaffold integration-test temp dirs (src/scaffold/scaffold.integration.test.ts
# cleans up after itself; this catches crashed runs)
/tests/scaffold-tmp-*/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
